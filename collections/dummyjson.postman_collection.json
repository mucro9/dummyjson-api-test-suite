            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/category/smartphones",
              "host": ["{{baseUrl}}"],
              "path": ["products", "category", "smartphones"]
            }
          }
        },
        {
          "name": "List categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Returns a non-empty list of category slugs', function () {",
                  "  pm.expect(body).to.be.an('array').that.is.not.empty;",
                  "  pm.expect(body).to.include('smartphones');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/category-list",
              "host": ["{{baseUrl}}"],
              "path": ["products", "category-list"]
            }
          }
        },
        {
          "name": "Sort by price (desc)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Results are sorted by price descending', function () {",
                  "  const prices = body.products.map(function (p) { return p.price; });",
                  "  const sorted = prices.slice().sort(function (a, b) { return b - a; });",
                  "  pm.expect(prices).to.eql(sorted);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?sortBy=price&order=desc&limit=10&select=title,price",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "sortBy", "value": "price" },
                { "key": "order", "value": "desc" },
                { "key": "limit", "value": "10" },
                { "key": "select", "value": "title,price" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Error Handling",
      "description": "Invalid, missing, and unexpected inputs across endpoints.",
      "item": [
        {
          "name": "Get product — non-existent id (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Returns a not-found message naming the id', function () {",
                  "  pm.expect(pm.response.json().message).to.match(/not found/i);",
                  "  pm.expect(pm.response.json().message).to.include('99999');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/products/99999", "host": ["{{baseUrl}}"], "path": ["products", "99999"] }
          }
        },
        {
          "name": "Get product — non-numeric id (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 404', function () {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Returns an error message', function () {",
